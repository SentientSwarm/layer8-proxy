# layer8-proxy site env vars. Copy to .env and fill in real values.
# .env is gitignored — never commit cleartext credentials.

# ─── Bundle versions (pinned via site.cfg too; this is the runtime) ──────
LOCKSMITH_VERSION=v2.0.0
PIPELOCK_VERSION=2.3.0

# ─── lf-scan internal token (locksmith ↔ lf-scan shared secret) ──────────
# Generate once: openssl rand -hex 32
LF_SCAN_INTERNAL_TOKEN=replace-me-with-secure-random-string

# ─── Hugging Face (for PromptGuard 2 model download in lf-scan) ──────────
# Get one at https://hf.co/settings/tokens after accepting
# https://hf.co/meta-llama/Prompt-Guard-2-86M terms.
HF_TOKEN=

# ─── Provider API keys (locksmith injects these on agent's behalf) ───────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_GATEWAY_API_KEY=
TAVILY_API_KEY=
GITHUB_TOKEN=
LM_STUDIO_API_KEY=

# ─── OAuth sealing key (Phase F) ──────────────────────────────────────────
# Required if you want to use OAuth providers (codex, copilot,
# anthropic-oauth, google-gemini-cli, qwen-cli). Generate once at
# install time:
#
#   openssl rand -base64 32
#
# Stash in your sealed-cred mechanism (systemd-creds / Keychain) and
# load it into the locksmith container's env at startup. Without it,
# OAuth registrations exist in /models discovery but proxy calls
# return 503 oauth_sealing_key_unset.
LOCKSMITH_OAUTH_SEALING_KEY=

# ─── Sealed-creds passphrase (macOS dev fallback) ────────────────────────
# On Linux production hosts, leave unset — secrets.bootstrap.sh +
# decrypt-creds.sh use systemd-creds + the kernel keyring.
# On macOS dev, set this to whatever passphrase you used at
# secrets.bootstrap.sh time.
LOCKSMITH_CREDS_PASSPHRASE=

# ─── Backup destination (used by backup.sh / cron/backup.cron) ───────────
# Examples:
#   BACKUP_DEST=/Volumes/NAS/layer8-backups
#   BACKUP_DEST=rest:https://restic.example.corp:8000/layer8-${HOSTNAME}
BACKUP_DEST=
RESTIC_PASSWORD_FILE=
RESTIC_PASSWORD_CREDS=./locksmith/secrets/restic_password.creds
BACKUP_RETENTION_DAYS=14
