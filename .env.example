# layer8-proxy bundle versions — pinned in hermes-site/site.cfg per host.
LOCKSMITH_VERSION=v2.1.0
PIPELOCK_VERSION=2.3.0
LF_SCAN_INTERNAL_TOKEN=replace-me-with-secure-random-string

# Hugging Face token for downloading PromptGuard 2 (gated model).
# Get one at https://hf.co/settings/tokens after accepting
# https://hf.co/meta-llama/Prompt-Guard-2-86M terms.
HF_TOKEN=

# Mount points — overridden by site repos.
LOCKSMITH_CONFIG_PATH=./locksmith/config.example.yaml
LOCKSMITH_SECRETS_DIR=./locksmith/secrets
PIPELOCK_CONFIG_PATH=./pipelock/pipelock.example.yaml
LOCKSMITH_DATA_VOLUME=locksmith_data
LOCKSMITH_LOG_VOLUME=locksmith_log
PIPELOCK_LOG_VOLUME=pipelock_log
